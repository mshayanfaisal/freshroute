{
  "name": "freshroute",
  "version": "1.0.0",
  "private": true,
  "description": "FreshRoute — AI-Powered Farm-to-Table Supply Chain Platform",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "build": "npm run build --workspace=apps/backend && npm run build --workspace=apps/frontend",
    "test": "npm run test --workspace=apps/backend",
    "test:e2e": "npm run test:e2e --workspace=apps/backend",
    "migration:run": "npm run migration:run --workspace=apps/backend",
    "seed": "npm run seed --workspace=apps/backend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
