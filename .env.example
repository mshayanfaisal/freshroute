# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=freshroute
POSTGRES_PASSWORD=freshroute_pw
POSTGRES_DB=freshroute

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=7d

# ─── AI ─────────────────────────────────────────────────────
# Provider: 'anthropic' or 'gemini'. Leave the selected provider's key blank
# to force graceful fallback mode.
AI_PROVIDER=anthropic
AI_ENABLED=true
AI_MAX_TOKENS=1024

# Anthropic (Claude)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── App ────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development
